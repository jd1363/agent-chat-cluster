{
  "schemaVersion": "1.0",
  "agents": [
    {
      "id": "agent-exec-01",
      "role": "executor",
      "type": "execution",
      "enabled": true,
      "cwd": "agents/resident/exec01",
      "riskLevel": "low",
      "notes": "Codex 执行引擎，通过 codex exec CLI 调用。主控→Agent 命令通道验证。",
      "displayName": "Codex",
      "executor": {
        "type": "cli",
        "command": "codex",
        "args": ["exec", "{prompt}"],
        "workDir": "G:\\agent-chat-cluster",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-01",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext01",
      "riskLevel": "medium",
      "notes": "CodeWhale 执行引擎，通过 codewhale exec --auto CLI 调用。",
      "displayName": "CodeWhale",
      "executor": {
        "type": "cli",
        "command": "codewhale",
        "args": ["exec", "--auto", "{prompt}"],
        "workDir": "G:\\agent-chat-cluster",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-02",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext02",
      "riskLevel": "medium",
      "notes": "OpenCode 执行引擎，通过 opencode run --dangerously-skip-permissions CLI 调用。",
      "displayName": "OpenCode",
      "executor": {
        "type": "cli",
        "command": "opencode",
        "args": ["run", "--dangerously-skip-permissions", "{prompt}"],
        "workDir": "G:\\agent-chat-cluster",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-03",
      "role": "external",
      "type": "extension",
      "enabled": false,
      "cwd": "agents/ext/ext03",
      "riskLevel": "medium",
      "notes": "Ollama 执行引擎，通过 ollama run CLI 调用，模型: maayan/Qwen2.5-14B-Instruct-GGUF:latest。",
      "displayName": "Ollama",
      "executor": {
        "type": "cli",
        "command": "ollama",
        "args": ["run", "maayan/Qwen2.5-14B-Instruct-GGUF:latest", "{prompt}"],
        "workDir": "G:\\agent-chat-cluster",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-04",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext04",
      "riskLevel": "medium",
      "notes": "MiMo 执行引擎，通过 mimo run --dangerously-skip-permissions CLI 调用。",
      "displayName": "MiMo",
      "executor": {
        "type": "cli",
        "command": "mimo",
        "args": ["run", "--dangerously-skip-permissions", "{prompt}"],
        "workDir": "G:\\agent-chat-cluster",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-05",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext05",
      "riskLevel": "medium",
      "notes": "Codex-2 执行引擎，通过 codex exec CLI 调用。第二实例。",
      "displayName": "Codex-2",
      "executor": {
        "type": "cli",
        "command": "codex",
        "args": ["exec", "{prompt}"],
        "workDir": "G:\\agent-chat-cluster",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-06",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext06",
      "riskLevel": "medium",
      "notes": "CodeWhale-2 执行引擎，通过 codewhale exec --auto CLI 调用。第二实例。",
      "displayName": "CodeWhale-2",
      "executor": {
        "type": "cli",
        "command": "codewhale",
        "args": ["exec", "--auto", "{prompt}"],
        "workDir": "G:\\agent-chat-cluster",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-hermes-01",
      "role": "executor",
      "type": "hermes",
      "enabled": false,
      "cwd": "agents/hermes/hermes01",
      "riskLevel": "medium",
      "notes": "Hermes Agent v0.10.0 真实执行后端。通过 hermes chat --quiet CLI 调用。模型: doubao-seed-2-0-code-preview-260215。",
      "backend": {
        "type": "hermes-cli",
        "command": "hermes",
        "args": [
          "chat",
          "-q",
          "{prompt}",
          "--quiet",
          "--max-turns",
          "30"
        ],
        "workDir": "G:\\hermers\\hermes-agent"
      }
    }
  ]
}
