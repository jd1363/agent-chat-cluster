{
  "schemaVersion": "1.0",
  "agents": [
    {
      "id": "agent-exec-01",
      "role": "executor",
      "type": "execution",
      "enabled": false,
      "cwd": "agents/resident/exec01",
      "riskLevel": "low",
      "notes": "[已禁用 2026-07-13] Codex 执行引擎。中转站 yuesecoding.top 已失效（Cloudflare 403），待重新配可用 base_url/key 后再启用。方案 C：绕开 codex。",
      "displayName": "Codex",
      "executor": {
        "type": "cli",
        "command": "codex",
        "args": [
          "exec",
          "{prompt}"
        ],
        "workDir": ".",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-01",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext01",
      "riskLevel": "medium",
      "notes": "CodeWhale 执行引擎，通过 codewhale exec --auto --output-format stream-json CLI 调用。",
      "displayName": "CodeWhale",
      "executor": {
        "type": "cli",
        "command": "codewhale",
        "args": [
          "exec",
          "--auto",
          "--output-format",
          "stream-json",
          "{prompt}"
        ],
        "workDir": ".",
        "timeoutSeconds": 300,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-02",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext02",
      "riskLevel": "medium",
      "notes": "OpenCode 执行引擎，通过 opencode run --dangerously-skip-permissions CLI 调用。",
      "displayName": "OpenCode",
      "executor": {
        "type": "cli",
        "command": "opencode",
        "args": [
          "run",
          "--dangerously-skip-permissions",
          "{prompt}"
        ],
        "workDir": ".",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-03",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext03",
      "riskLevel": "medium",
      "notes": "[本地兑底 2026-07-13] Ollama 执行引擎，模型 qwen2.5:7b（本地已存在）。作为 codex 失效后的本地兑底启用。",
      "displayName": "Ollama",
      "executor": {
        "type": "cli",
        "command": "ollama",
        "args": [
          "run",
          "qwen2.5:7b",
          "{prompt}"
        ],
        "workDir": ".",
        "timeoutSeconds": 300,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-04",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext04",
      "riskLevel": "medium",
      "notes": "MiMo 执行引擎，通过 mimo run --dangerously-skip-permissions CLI 调用。",
      "displayName": "MiMo",
      "executor": {
        "type": "cli",
        "command": "mimo",
        "args": [
          "run",
          "--dangerously-skip-permissions",
          "{prompt}"
        ],
        "workDir": ".",
        "timeoutSeconds": 120,
        "maxOutputKB": 1024,
        "env": {
          "LANG": "en_US.UTF-8",
          "LC_ALL": "en_US.UTF-8",
          "PYTHONUTF8": "1",
          "PYTHONIOENCODING": "utf-8"
        }
      }
    },
    {
      "id": "agent-ext-05",
      "role": "external",
      "type": "extension",
      "enabled": false,
      "cwd": "agents/ext/ext05",
      "riskLevel": "medium",
      "notes": "[已禁用 2026-07-13] Codex-2 执行引擎。同 agent-exec-01，中转站 yuesecoding.top 失效，方案 C 绕开 codex。",
      "displayName": "Codex-2",
      "executor": {
        "type": "cli",
        "command": "codex",
        "args": [
          "exec",
          "{prompt}"
        ],
        "workDir": ".",
        "timeoutSeconds": 300,
        "maxOutputKB": 1024
      }
    },
    {
      "id": "agent-ext-06",
      "role": "external",
      "type": "extension",
      "enabled": true,
      "cwd": "agents/ext/ext06",
      "riskLevel": "medium",
      "notes": "CodeWhale-2 执行引擎，通过 codewhale exec --auto --output-format stream-json CLI 调用。第二实例。",
      "displayName": "CodeWhale-2",
      "executor": {
        "type": "cli",
        "command": "codewhale",
        "args": [
          "exec",
          "--auto",
          "--output-format",
          "stream-json",
          "{prompt}"
        ],
        "workDir": ".",
        "timeoutSeconds": 300,
        "maxOutputKB": 1024
      }
    }
  ]
}